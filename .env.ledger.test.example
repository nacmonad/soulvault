# Copy to `.env.ledger.test` (gitignored) for `pnpm test:ledger` in `cli/`.
#
# The funder key (SOULVAULT_PRIVATE_KEY) must control a funded account on your
# dev chain (e.g. anvil account #0). It only sends native token to the Ledger
# address and funds "alice" for member-side txs — it does NOT own the contracts.
#
# SOULVAULT_LEDGER_TEST_ADDRESS must match the address for SOULVAULT_LEDGER_DERIVATION_PATH
# on your Ledger (same path as normal CLI ledger mode).

SOULVAULT_SIGNER_MODE=ledger
SOULVAULT_LEDGER_AUTO_SYNC=false
SOULVAULT_LEDGER_CONFIRM_ADDRESS=false

SOULVAULT_LEDGER_TEST_ADDRESS=0xYourLedgerAddressHere
SOULVAULT_LEDGER_DERIVATION_PATH=m/44'/60'/0'/0/0

# Funder: anvil/hardhat first account (or any key with balance on the RPC chain)
SOULVAULT_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Match your local integration harness (ens-app-v3 / anvil)
SOULVAULT_RPC_URL=http://127.0.0.1:8545
SOULVAULT_CHAIN_ID=31337
SOULVAULT_ENS_RPC_URL=http://127.0.0.1:8545
