# SoulVault signer configuration
# Choose exactly one signer mode for the CLI.
# Supported: mnemonic | private-key | ledger
SOULVAULT_SIGNER_MODE=mnemonic

# --- Mnemonic mode ---
# Used when SOULVAULT_SIGNER_MODE=mnemonic
SOULVAULT_MNEMONIC="test test test test test test test test test test test junk"
SOULVAULT_MNEMONIC_PATH="m/44'/60'/0'/0/0"

# --- Private key mode ---
# Used when SOULVAULT_SIGNER_MODE=private-key
SOULVAULT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# --- Ledger mode ---
# Used when SOULVAULT_SIGNER_MODE=ledger
# MVP note: planned signer mode; keep values here for forward compatibility.
SOULVAULT_LEDGER_DERIVATION_PATH="m/44'/60'/0'/0/0"

# Chain / RPC
SOULVAULT_RPC_URL=https://evmrpc-testnet.0g.ai
SOULVAULT_CHAIN_ID=16601

# 0G storage / indexing
SOULVAULT_0G_STORAGE_URL=
SOULVAULT_0G_INDEXER_URL=
SOULVAULT_0G_AUTH_TOKEN=

# Optional default contracts / settings
SOULVAULT_ERC8004_REGISTRY_ADDRESS=
SOULVAULT_DEFAULT_SWARM_ADDRESS=
SOULVAULT_DEFAULT_HARNESS=openclaw

# Optional profile / workspace defaults
SOULVAULT_PROFILE=default
SOULVAULT_WORKSPACE=
